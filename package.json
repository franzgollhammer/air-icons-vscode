{
  "name": "air-file-icons",
  "displayName": "Air File Icons",
  "description": "JetBrains Air-inspired file icon theme for VS Code",
  "version": "0.1.0",
  "publisher": "fg",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "iconThemes": [
      {
        "id": "air-file-icons",
        "label": "Air File Icons",
        "path": "./air-icon-theme.json"
      }
    ],
    "configurationDefaults": {
      "workbench.tree.indent": 20
    }
  },
  "scripts": {
    "dev": "code --extensionDevelopmentPath=$PWD",
    "dev:insiders": "code-insiders --extensionDevelopmentPath=$PWD",
    "package": "npx @vscode/vsce package",
    "install:local": "npx @vscode/vsce package && code --install-extension $(ls -t *.vsix | head -1) --force"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fg/air-icons-vscode"
  }
}
