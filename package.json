{
  "name": "air-file-icons",
  "displayName": "Air File Icons",
  "description": "Air-inspired file icon themes for VS Code and Cursor, including an expansive Material set.",
  "version": "0.2.0",
  "publisher": "franzgollhammer",
  "author": {
    "name": "Franz Gollhammer"
  },
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "icons",
    "icon-theme",
    "file-icons",
    "jetbrains",
    "air",
    "minimal",
    "theme",
    "cursor"
  ],
  "galleryBanner": {
    "color": "#2B2D30",
    "theme": "dark"
  },
  "qna": "marketplace",
  "pricing": "Free",
  "contributes": {
    "iconThemes": [
      {
        "id": "air-file-icons",
        "label": "Air File Icons",
        "path": "./air-icon-theme.json"
      },
      {
        "id": "air-material-icons",
        "label": "Air Material Icons",
        "path": "./air-material-icon-theme.json"
      }
    ],
    "configurationDefaults": {
      "workbench.tree.indent": 20
    }
  },
  "scripts": {
    "dev": "code --extensionDevelopmentPath=$PWD",
    "dev:insiders": "code-insiders --extensionDevelopmentPath=$PWD",
    "package": "bash scripts/package.sh",
    "package:list": "npx @vscode/vsce ls",
    "publish": "bash scripts/publish-all.sh",
    "publish:vscode": "bash scripts/publish-vscode.sh",
    "publish:openvsx": "bash scripts/publish-openvsx.sh",
    "release": "bash scripts/release.sh",
    "install:local": "bash scripts/install-local.sh",
    "sync:zed": "python3 scripts/sync_from_zed.py",
    "verify": "bash scripts/verify.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/franzgollhammer/air-icons-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/franzgollhammer/air-icons-vscode/issues"
  },
  "homepage": "https://github.com/franzgollhammer/air-icons-vscode#readme",
  "icon": "air-icons.png"
}
